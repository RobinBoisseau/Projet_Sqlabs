  "item": [
    {
      "name": "Authenticator",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse JSON response\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "// 1. Vérifier le status HTTP\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Vérifier que le schema de la Response est valide\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"user\", \"token\"],\r",
                  "    properties: {\r",
                  "        user: {\r",
                  "            type: \"object\",\r",
                  "            required: [\"id\", \"name\", \"email\", \"role\"],\r",
                  "            properties: {\r",
                  "                id: { type: \"number\" },\r",
                  "                name: { type: \"string\" },\r",
                  "                email: { type: \"string\" },\r",
                  "                role: { type: \"string\" }\r",
                  "            }\r",
                  "        },\r",
                  "        token: { type: \"string\" }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Response schema is valid\", function () {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});\r",
                  "\r",
                  "// 5. Sauvegarder le token\r",
                  "pm.collectionVariables.set(\"token\", response.token);\r",
                  "\r",
                  "// 6. Sauvegarder infos utiles\r",
                  "pm.collectionVariables.set(\"user_id\", response.user.id);\r",
                  "pm.collectionVariables.set(\"user_email\", response.user.email);\r",
                  "pm.collectionVariables.set(\"user_role\", response.user.role);\r",
                  "\r",
                  "console.log(\"Token saved:\", response.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"admin@sqlabs.fr\",\r\n    \"password\": \"admin1234\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
