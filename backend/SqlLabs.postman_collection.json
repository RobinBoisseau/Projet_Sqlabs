    {
      "name": "Exercices",
      "item": [
        {
          "name": "Lister les exercies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse JSON response\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "// 1. Vérifier le status HTTP\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Vérifier que le schema de la Response est valide\r",
                  "pm.test(\"Response has data array\", () => {\r",
                  "    pm.expect(response.data).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"data\"],\r",
                  "    properties: {\r",
                  "        data: {\r",
                  "            type: \"array\",\r",
                  "            items: {\r",
                  "                type: \"object\",\r",
                  "                required: [\"id\", \"title\", \"slug\", \"type\", \"status\", \"statement\"],\r",
                  "                properties: {\r",
                  "                    id: { type: \"integer\" },\r",
                  "                    title: { type: \"string\" },\r",
                  "                    slug: { type: \"string\" },\r",
                  "                    type: { type: \"string\" },\r",
                  "                    status: { type: \"string\" },\r",
                  "                    statement: { type: \"string\" }\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Schema is valid\", () => {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/exercices",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "exercices"
              ]
            }
          },
          "response": []
        }
      ]
    },
